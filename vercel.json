{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ssimba.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "public": [
    "/manifest.json",
    "/:locale/manifest.json",
    "/en/manifest.json",
    "/fr/manifest.json",
    "/rw/manifest.json",
    "/sw/manifest.json",
    "/favicon.ico",
    "/sw.js",
    "/browserconfig.xml"
  ]
}
