{
  "rewrites": [
    {
      "source": "/api/products/:path*",
      "destination": "https://ssimba.onrender.com/api/products/:path*"
    },
    {
      "source": "/api/categories/:path*",
      "destination": "https://ssimba.onrender.com/api/categories/:path*"
    },
    {
      "source": "/api/orders/:path*",
      "destination": "https://ssimba.onrender.com/api/orders/:path*"
    },
    {
      "source": "/api/reviews/:path*",
      "destination": "https://ssimba.onrender.com/api/reviews/:path*"
    },
    {
      "source": "/api/banners/:path*",
      "destination": "https://ssimba.onrender.com/api/banners/:path*"
    },
    {
      "source": "/api/branches/:path*",
      "destination": "https://ssimba.onrender.com/api/branches/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://ssimba.onrender.com/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/(manifest.json|.*\\/manifest.json|favicon.ico|sw.js|browserconfig.xml)",
      "headers": [
        {
          "key": "x-vercel-protection-bypass",
          "value": "public"
        }
      ]
    }
  ]
}
